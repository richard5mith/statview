PROMETHEUS_URL=http://host.docker.internal:9090
# Optional HTTP basic auth for Prometheus
PROMETHEUS_USERNAME=
PROMETHEUS_PASSWORD=
LIVE_REFRESH_SECONDS=15

# Required in all modes; signs the Flask session cookie.
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(48))'
SECRET_KEY=

# Optional: GitHub gatekeeping. Leave AUTH_TYPE unset (or =none) for no auth.
# AUTH_TYPE=github
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_ALLOWED_USERS=alice,bob
# GITHUB_ALLOWED_ORG=
# OAUTH_REDIRECT_URL=
